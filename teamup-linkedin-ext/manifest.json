{
  "manifest_version": 3,
  "name": "TeamUp Lead Capture",
  "version": "1.0.0",
  "description": "One-click LinkedIn lead capture to Zoho CRM",
  "permissions": ["activeTab", "storage", "clipboardRead"],
  "host_permissions": ["https://*.onrender.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*", "https://www.linkedin.com/sales/lead/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
